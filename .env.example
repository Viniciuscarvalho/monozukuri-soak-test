# Copy this file to .env and fill in your values.
# Only set secrets for providers you use.

# Linear (required when source.adapter = linear)
LINEAR_API_KEY=

# Jira (required when source.adapter = jira)
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# Notion (required when source.adapter = notion)
NOTION_TOKEN=

# GitHub: uses gh CLI auth. Run: gh auth login
